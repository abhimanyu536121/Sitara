rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidProfile(data) {
      return data.keys().hasAll(['uid', 'creatorName', 'assistantName', 'updatedAt']) 
        && data.keys().size() >= 4 && data.keys().size() <= 5
        && data.uid is string && data.uid.size() <= 128
        && data.creatorName is string && data.creatorName.size() <= 64
        && data.assistantName is string && data.assistantName.size() <= 64
        && (!data.keys().hasAll(['preferences']) || (data.preferences is string && data.preferences.size() <= 10000))
        && data.updatedAt == request.time;
    }
    
    function isValidChatMessage(data) {
      return data.keys().hasAll(['id', 'sender', 'text', 'timestamp', 'uid'])
        && data.keys().size() == 5
        && data.id is string && data.id.size() <= 128
        && data.sender is string && (data.sender == 'user' || data.sender == 'sitara')
        && data.text is string && data.text.size() <= 5000
        && data.timestamp == request.time
        && data.uid is string && data.uid.size() <= 128;
    }
    
    match /profiles/{uid} {
      allow get: if isOwner(uid);
      allow create: if isOwner(uid) && isValidProfile(incoming()) && incoming().uid == uid;
      allow update: if isOwner(uid) && isValidProfile(incoming()) && incoming().uid == uid 
                     && incoming().uid == existing().uid
                     && incoming().diff(existing()).affectedKeys().hasOnly(['creatorName', 'assistantName', 'preferences', 'updatedAt']);
      allow delete: if isOwner(uid);
      
      match /messages/{messageId} {
        allow get: if isOwner(uid);
        allow list: if isOwner(uid);
        allow create: if isOwner(uid) && isValidId(messageId) && isValidChatMessage(incoming()) && incoming().uid == uid;
        // Messages are immutable historical chat entries
        allow update, delete: if false;
      }
    }
  }
}
